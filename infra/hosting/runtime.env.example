# Copy to /etc/legal-mcp/runtime.env (root:root 0600).
# Hosted startup fails closed unless this is api-key, entra, or entra+api-key.
LEGAL_MCP_HTTP_AUTH=api-key
LEGAL_MCP_API_KEYS_FILE=/run/secrets/legal-mcp-api-keys.json
LEGAL_MCP_EXTERNAL_URL=https://legal.example.com/mcp
LEGAL_MCP_ALLOWED_ORIGINS=https://legal.example.com
LEGAL_MCP_HTTP_WORKERS=4
LEGAL_MCP_SHUTDOWN_GRACE_SECONDS=30

# Required only for entra or entra+api-key. Values are identifiers, not secrets.
# LEGAL_MCP_ENTRA_TENANT_ID=11111111-1111-1111-1111-111111111111
# LEGAL_MCP_ENTRA_SERVER_APP_ID=22222222-2222-2222-2222-222222222222
# LEGAL_MCP_ENTRA_AUDIENCES=22222222-2222-2222-2222-222222222222,api://22222222-2222-2222-2222-222222222222
# LEGAL_MCP_ENTRA_SCOPE=legal.read
# LEGAL_MCP_ENTRA_SCOPE_URI=api://22222222-2222-2222-2222-222222222222/legal.read
# LEGAL_MCP_ENTRA_ALLOWED_CLIENT_IDS=33333333-3333-3333-3333-333333333333
