LEGAL_MCP_DATA_DIR=/var/lib/australian-legal-mcp
LEGAL_MCP_HTTP_WORKERS=2
LEGAL_MCP_SHUTDOWN_GRACE_SECONDS=30
ORT_DYLIB_PATH=/usr/local/lib/australian-legal-mcp/libonnxruntime.so

# Keep disabled while access is SSH-tunnel-only. Hosted mode must use api-key,
# entra, or entra+api-key and add --require-http-auth to ExecStart.
LEGAL_MCP_HTTP_AUTH=disabled
# LEGAL_MCP_API_KEYS_FILE=/run/secrets/legal-mcp-api-keys.json
# LEGAL_MCP_EXTERNAL_URL=https://legal.example.com/mcp
# LEGAL_MCP_ENTRA_TENANT_ID=11111111-1111-1111-1111-111111111111
# LEGAL_MCP_ENTRA_SERVER_APP_ID=22222222-2222-2222-2222-222222222222
# LEGAL_MCP_ENTRA_AUDIENCES=22222222-2222-2222-2222-222222222222,api://22222222-2222-2222-2222-222222222222
# LEGAL_MCP_ENTRA_SCOPE=legal.read
# LEGAL_MCP_ENTRA_SCOPE_URI=api://22222222-2222-2222-2222-222222222222/legal.read
# Comma-separated exact connector/caller app IDs. For Copilot Studio this is
# the connector app. Add Microsoft's documented enterprise token-store app ID
# only when enabling the Microsoft 365 declarative-agent SSO path.
# LEGAL_MCP_ENTRA_ALLOWED_CLIENT_IDS=33333333-3333-3333-3333-333333333333

# Cloud connectors normally omit Origin. Add only observed, exact HTTPS origins;
# this setting is not CORS support and does not replace bearer authentication.
# LEGAL_MCP_ALLOWED_ORIGINS=https://example.invalid
