LEGAL_MCP_DATA_DIR=/var/lib/australian-legal-mcp
LEGAL_MCP_HTTP_WORKERS=2
LEGAL_MCP_SHUTDOWN_GRACE_SECONDS=30
# Set this to the exact HTTPS origin if browser-based MCP clients are used.
# Non-browser MCP clients normally omit Origin.
# LEGAL_MCP_ALLOWED_ORIGINS=https://legal-mcp.example.ts.net
# CPU runtime needs the ONNX Runtime shared library shipped with the binary.
ORT_DYLIB_PATH=/usr/local/lib/australian-legal-mcp/libonnxruntime.so
