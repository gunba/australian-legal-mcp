#!/usr/bin/env bash
# Root-only transactional activation helper for the provider-neutral OCI host.
set -euo pipefail
umask 027
export LC_ALL=C
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

[[ $EUID -eq 0 ]] || { echo 'legal-mcp-host-deploy must run as root' >&2; exit 2; }
[[ $# -eq 2 ]] || {
  echo 'usage: legal-mcp-host-deploy prepare|activate|abort GENERATION' >&2
  exit 2
}
ACTION="$1"
GENERATION="$2"
[[ "$ACTION" = prepare || "$ACTION" = activate || "$ACTION" = abort ]] || {
  [[ "$ACTION" = pair-seal || "$ACTION" = pair-activate \
    || "$ACTION" = pair-restore || "$ACTION" = pair-commit ]] || {
    echo 'invalid deployment action' >&2
    exit 2
  }
}
[[ "$GENERATION" =~ ^[0-9a-f]{64}$ ]] || { echo 'generation ID is malformed' >&2; exit 2; }
PAIR_ACTION=false
[[ "$ACTION" == pair-* ]] && PAIR_ACTION=true
DATA_ROOT=/srv/legal-mcp
GENERATIONS="$DATA_ROOT/generations"
LIFECYCLE="$DATA_ROOT/lifecycle"
UPLOADS="$DATA_ROOT/uploads"
STATE="$DATA_ROOT/state"
LIFECYCLE_LOCK="$LIFECYCLE/LIFECYCLE_LOCK"
JOURNAL="$LIFECYCLE/.deployment-transaction"
JOURNAL_PREPARING="$LIFECYCLE/.deployment-transaction.preparing"
IMAGE_FILE=/etc/legal-mcp/image
AUTH_READY=/etc/legal-mcp/auth-ready
PAIR_TRANSACTION=/etc/legal-mcp/.image-transaction
SERVICE=legal-mcp.service
LOCK_FILE=/run/lock/legal-mcp-host-transaction.lock
RUNTIME_CONTROL=/run/legal-mcp
UPLOAD_AUTHORIZATION="$RUNTIME_CONTROL/authorized-upload"
PUBLISHER=legal-mcp-publisher
SERVICE_USER=legal-mcp

require_commands() {
  local command_name
  for command_name in "$@"; do
    command -v "$command_name" >/dev/null || {
      echo "missing host dependency: $command_name" >&2
      exit 1
    }
  done
}

require_commands flock getfacl rm stat sync

[[ -f "$LOCK_FILE" && ! -L "$LOCK_FILE" \
  && "$(stat -c '%U:%G:%a:%h' "$LOCK_FILE")" = root:legal-mcp-publisher:640:1 ]] || {
  echo 'host transaction lock is missing or unsafe' >&2
  exit 1
}
INHERITED_LOCK_FD="${LEGAL_MCP_HOST_TRANSACTION_LOCK_FD:-9}"
if [[ "$PAIR_ACTION" = true \
  && "$INHERITED_LOCK_FD" =~ ^[0-9]+$ \
  && -e "/proc/$$/fd/$INHERITED_LOCK_FD" \
  && "$(stat -Lc '%d:%i' "/proc/$$/fd/$INHERITED_LOCK_FD" 2>/dev/null || true)" \
    = "$(stat -Lc '%d:%i' "$LOCK_FILE")" ]]; then
  HOST_LOCK_FD="$INHERITED_LOCK_FD"
else
  exec 9<>"$LOCK_FILE"
  HOST_LOCK_FD=9
fi
flock -x "$HOST_LOCK_FD"

require_owner_mode() {
  local path="$1" owner="$2" group="$3" mode="$4"
  [[ ! -L "$path" ]] || { echo "symlink rejected: $path" >&2; exit 1; }
  [[ "$(stat -c '%U:%G:%a' "$path")" = "$owner:$group:$mode" ]] || {
    echo "unsafe owner or mode for $path" >&2
    exit 1
  }
}

require_acl() {
  local path="$1" expected="$2"
  [[ "$(getfacl --absolute-names --numeric --omit-header "$path")" = "$expected" ]] || {
    echo "unsafe access ACL for $path" >&2
    exit 1
  }
}

read_systemctl_activity() {
  local unit="$1" output status
  if output="$(systemctl is-active "$unit" 2>/dev/null)"; then
    status=0
  else
    status=$?
  fi
  case "$status:$output" in
    0:active|3:inactive) printf '%s\n' "$output" ;;
    *)
      echo "could not determine exact systemd activity for $unit (status $status, state ${output:-<empty>})" >&2
      return 1
      ;;
  esac
}

read_systemctl_enablement() {
  local unit="$1" output status
  if output="$(systemctl is-enabled "$unit" 2>/dev/null)"; then
    status=0
  else
    status=$?
  fi
  case "$status:$output" in
    0:enabled|0:generated|1:disabled) printf '%s\n' "$output" ;;
    *)
      echo "could not determine exact systemd enablement for $unit (status $status, state ${output:-<empty>})" >&2
      return 1
      ;;
  esac
}

podman_image_state() {
  local image="$1" status
  if podman image exists "$image"; then
    printf '%s\n' present
    return 0
  else
    status=$?
  fi
  if [[ $status -eq 1 ]]; then
    printf '%s\n' absent
    return 0
  fi
  echo "could not inspect Podman image state for $image (status $status)" >&2
  return 1
}

require_fixed_host_identities() {
  publisher_uid="$(id -u "$PUBLISHER")"
  publisher_gid="$(id -g "$PUBLISHER")"
  [[ "$publisher_uid" = 973 && "$publisher_gid" = 973 \
    && "$(id -G "$PUBLISHER")" = 973 ]] || {
    echo 'publisher identity does not match the fixed host contract' >&2
    return 1
  }
  [[ "$(id -u "$SERVICE_USER")" = 971 && "$(id -g "$SERVICE_USER")" = 971 \
    && "$(id -G "$SERVICE_USER")" = 971 ]] || {
    echo 'service identity does not match the fixed host contract' >&2
    return 1
  }
}

validate_host_state() {
  local target source fstype options marker_uuid host_uuid actual_uuid xfs_details expected_acl directory
  local -a marker host_marker
  [[ -f /etc/legal-mcp/host-installed && ! -L /etc/legal-mcp/host-installed \
    && "$(stat -c '%U:%G:%a:%h' /etc/legal-mcp/host-installed)" = root:root:444:1 ]] || {
    echo 'installed host identity marker is missing' >&2
    exit 1
  }
  require_acl /etc/legal-mcp/host-installed $'user::r--\ngroup::r--\nother::r--'
  mapfile -t host_marker < /etc/legal-mcp/host-installed
  [[ ${#host_marker[@]} -eq 2 && "${host_marker[0]}" = LEGAL_MCP_HOST_V1 \
    && "${host_marker[1]}" =~ ^VOLUME_UUID=([0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12})$ ]] || {
    echo 'installed host identity marker is malformed' >&2
    exit 1
  }
  host_uuid="${BASH_REMATCH[1],,}"
  read -r target source fstype options < <(findmnt --noheadings --raw --output TARGET,SOURCE,FSTYPE,OPTIONS --target "$DATA_ROOT")
  [[ "$target" = "$DATA_ROOT" && "$fstype" = xfs \
    && ",$options," = *,noatime,* && ",$options," = *,nodev,* \
    && ",$options," = *,noexec,* && ",$options," = *,nosuid,* ]] || {
    echo "$DATA_ROOT must be the exact XFS volume mount" >&2
    exit 1
  }
  xfs_details="$(xfs_info "$DATA_ROOT")"
  if ! grep -Eq 'reflink=1([[:space:]]|$)' <<< "$xfs_details" \
    || ! grep -Eq 'ftype=1([[:space:]]|$)' <<< "$xfs_details"; then
    echo 'the corpus XFS volume must have reflink and directory file types enabled' >&2
    exit 1
  fi
  [[ -f "$DATA_ROOT/.legal-mcp-volume" && ! -L "$DATA_ROOT/.legal-mcp-volume" \
    && "$(stat -c '%U:%G:%a:%h' "$DATA_ROOT/.legal-mcp-volume")" = root:root:444:1 ]] || {
    echo 'corpus volume identity marker is missing' >&2
    exit 1
  }
  require_acl "$DATA_ROOT/.legal-mcp-volume" $'user::r--\ngroup::r--\nother::r--'
  mapfile -t marker < "$DATA_ROOT/.legal-mcp-volume"
  [[ ${#marker[@]} -eq 2 && "${marker[0]}" = LEGAL_MCP_VOLUME_V1 \
    && "${marker[1]}" =~ ^UUID=([0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12})$ ]] || {
    echo 'corpus volume identity marker is malformed' >&2
    exit 1
  }
  marker_uuid="${BASH_REMATCH[1],,}"
  actual_uuid="$(blkid -s UUID -o value "$source")"
  [[ "$host_uuid" = "$marker_uuid" && "${actual_uuid,,}" = "$marker_uuid" ]] || {
    echo 'host and mounted corpus volume identities do not match' >&2
    exit 1
  }

  require_owner_mode "$DATA_ROOT" root legal-mcp 750
  expected_acl=$'user::rwx\nuser:973:--x\ngroup::r-x\nmask::r-x\nother::---'
  [[ "$(getfacl --absolute-names --numeric --omit-header "$DATA_ROOT")" = "$expected_acl" ]] || {
    echo 'corpus root traversal ACL does not match the publisher contract' >&2
    exit 1
  }
  for directory in "$GENERATIONS" "$LIFECYCLE" "$STATE" "$UPLOADS"; do
    [[ -d "$directory" && ! -L "$directory" ]] || {
      echo "required host directory is missing or unsafe: $directory" >&2
      exit 1
    }
  done
  require_owner_mode "$GENERATIONS" root legal-mcp 750
  require_acl "$GENERATIONS" $'user::rwx\ngroup::r-x\nother::---'
  require_owner_mode "$LIFECYCLE" root legal-mcp 750
  require_acl "$LIFECYCLE" $'user::rwx\ngroup::r-x\nother::---'
  require_owner_mode "$STATE" legal-mcp legal-mcp 700
  require_acl "$STATE" $'user::rwx\ngroup::---\nother::---'
  require_owner_mode "$UPLOADS" legal-mcp-publisher legal-mcp-publisher 700
  require_acl "$UPLOADS" $'user::rwx\ngroup::---\nother::---'
  require_owner_mode "$LIFECYCLE/LOCK" root legal-mcp 640
  require_acl "$LIFECYCLE/LOCK" $'user::rw-\ngroup::r--\nother::---'
  [[ "$(stat -c '%h' "$LIFECYCLE/LOCK")" = 1 ]] || {
    echo 'corpus lock must have exactly one link' >&2
    exit 1
  }
  [[ -f "$LIFECYCLE_LOCK" && ! -L "$LIFECYCLE_LOCK" \
    && "$(stat -c '%U:%G:%a:%h:%s' "$LIFECYCLE_LOCK")" = root:root:640:1:0 ]] || {
    echo 'lifecycle lock is missing or unsafe' >&2
    exit 1
  }
  require_acl "$LIFECYCLE_LOCK" $'user::rw-\ngroup::r--\nother::---'
}

read_image() {
  local image_state
  [[ -f "$IMAGE_FILE" && ! -L "$IMAGE_FILE" ]] || { echo 'pinned image file is missing' >&2; exit 1; }
  require_owner_mode "$IMAGE_FILE" root root 600
  IMAGE="$(<"$IMAGE_FILE")"
  [[ "$IMAGE" =~ ^ghcr\.io/gunba/australian-legal-mcp@sha256:[0-9a-f]{64}$ ]] || {
    echo 'image must be the canonical GHCR repository pinned by digest' >&2
    exit 1
  }
  image_state="$(podman_image_state "$IMAGE")" || exit 1
  [[ "$image_state" = present ]] || { echo 'pinned legal-mcp image is not present' >&2; exit 1; }
}

run_legal_container() {
  local profile="$1"
  shift
  local -a capability_args=()
  case "$profile" in
    capability-free) ;;
    prepared-upload-activation)
      [[ $# -eq 5 \
        && "$1" = activate \
        && "$2" = --generation-dir \
        && "$3" = "/var/lib/legal-mcp/uploads/$GENERATION" \
        && "$4" = --expected-generation \
        && "$5" = "$GENERATION" ]] || {
        echo 'upload activation capability requested for an unexpected command' >&2
        return 1
      }
      capability_args=(--cap-add=dac_override)
      ;;
    *)
      echo 'unknown one-shot container capability profile' >&2
      return 1
      ;;
  esac

  podman run --rm \
    --network=none \
    --user=0:0 \
    --read-only \
    --cap-drop=all \
    "${capability_args[@]}" \
    --security-opt=no-new-privileges \
    --pids-limit=256 \
    --memory=6g \
    --memory-swap=6g \
    --tmpfs=/tmp:rw,nodev,nosuid,noexec,size=64m,mode=1777 \
    --volume="$DATA_ROOT:/var/lib/legal-mcp:rw,nodev,nosuid" \
    "$IMAGE" "$@"
}

run_legal() {
  run_legal_container capability-free "$@"
}

activate_prepared_upload() {
  run_legal_container prepared-upload-activation \
    activate \
    --generation-dir "/var/lib/legal-mcp/uploads/$GENERATION" \
    --expected-generation "$GENERATION"
}

active_generation() {
  local pointer="$LIFECYCLE/active-generation"
  if [[ ! -e "$pointer" && ! -L "$pointer" ]]; then
    printf '%s\n' '-'
    return
  fi
  [[ -f "$pointer" && ! -L "$pointer" && "$(stat -c '%h:%s' "$pointer")" = 1:64 ]] || {
    echo 'active-generation pointer is unsafe' >&2
    exit 1
  }
  local value
  value="$(<"$pointer")"
  [[ "$value" =~ ^[0-9a-f]{64}$ && -d "$GENERATIONS/$value" && ! -L "$GENERATIONS/$value" ]] || {
    echo 'active-generation pointer is invalid' >&2
    exit 1
  }
  printf '%s\n' "$value"
}

write_journal() {
  local phase="$1" previous="$2"
  [[ "$phase" =~ ^(preparing|prepared|aborting|activating|activated|rolling-back|rolled-back)$ ]] || exit 1
  [[ "$previous" = - || "$previous" =~ ^[0-9a-f]{64}$ ]] || exit 1
  path_is_absent "$JOURNAL_PREPARING" || {
    echo 'deployment journal preparation was not reconciled' >&2
    exit 1
  }
  printf '%s\n%s\n%s\n' "$GENERATION" "$previous" "$phase" > "$JOURNAL_PREPARING"
  chown root:root "$JOURNAL_PREPARING"
  chmod 600 "$JOURNAL_PREPARING"
  sync -f "$JOURNAL_PREPARING"
  mv -fT "$JOURNAL_PREPARING" "$JOURNAL"
  sync -f "$LIFECYCLE"
}

read_journal() {
  [[ -f "$JOURNAL" && ! -L "$JOURNAL" && "$(stat -c '%U:%G:%a:%h' "$JOURNAL")" = root:root:600:1 ]] || {
    echo 'deployment transaction journal is unsafe' >&2
    exit 1
  }
  mapfile -t transaction < "$JOURNAL"
  [[ ${#transaction[@]} -eq 3 \
    && "${transaction[0]}" =~ ^[0-9a-f]{64}$ \
    && ( "${transaction[1]}" = - || "${transaction[1]}" =~ ^[0-9a-f]{64}$ ) \
    && "${transaction[2]}" =~ ^(preparing|prepared|aborting|activating|activated|rolling-back|rolled-back)$ ]] || {
    echo 'deployment transaction journal is malformed' >&2
    exit 1
  }
  TX_GENERATION="${transaction[0]}"
  TX_PREVIOUS="${transaction[1]}"
  TX_PHASE="${transaction[2]}"
}

normalize_upload_for_activation() {
  local upload="$UPLOADS/$GENERATION"
  [[ -d "$upload" && ! -L "$upload" ]] || { echo 'prepared upload is missing' >&2; exit 1; }
  setfacl --recursive --remove-all "$upload"
  chown -R root:legal-mcp "$upload"
  find "$upload" -xdev -type d -exec chmod 750 {} +
  find "$upload" -xdev -type f -exec chmod 640 {} +
  sync -f "$upload"
}

seal_upload_for_pair() {
  local upload="$UPLOADS/$GENERATION"
  [[ -d "$upload" && ! -L "$upload" ]] || { echo 'pair candidate upload is missing' >&2; exit 1; }
  setfacl --recursive --remove-all "$upload"
  chown -R root:legal-mcp "$upload"
  find "$upload" -xdev -type d -exec chmod 550 {} +
  find "$upload" -xdev -type f -exec chmod 440 {} +
  sync -f "$upload"
}

restore_upload_to_publisher() {
  local upload="$UPLOADS/$GENERATION"
  [[ -d "$upload" && ! -L "$upload" ]] || return 0
  setfacl --recursive --remove-all "$upload"
  chown -R "$PUBLISHER:$PUBLISHER" "$upload"
  find "$upload" -xdev -type d -exec chmod 700 {} +
  find "$upload" -xdev -type f -exec chmod 600 {} +
  sync -f "$upload"
}

clear_upload_authorization() {
  [[ -d "$RUNTIME_CONTROL" && ! -L "$RUNTIME_CONTROL" \
    && "$(stat -c '%U:%G:%a' "$RUNTIME_CONTROL")" = root:legal-mcp-publisher:710 ]] || {
    echo 'runtime upload-control directory is unsafe' >&2
    exit 1
  }
  rm -f -- "$UPLOAD_AUTHORIZATION"
  [[ ! -e "$UPLOAD_AUTHORIZATION" && ! -L "$UPLOAD_AUTHORIZATION" ]] || {
    echo 'upload authorization revocation did not complete' >&2
    exit 1
  }
  sync -f "$RUNTIME_CONTROL"
}

authorize_upload() {
  local temporary="$RUNTIME_CONTROL/.authorized-upload.$$.tmp"
  [[ -d "$RUNTIME_CONTROL" && ! -L "$RUNTIME_CONTROL" \
    && "$(stat -c '%U:%G:%a' "$RUNTIME_CONTROL")" = root:legal-mcp-publisher:710 ]] || {
    echo 'runtime upload-control directory is unsafe' >&2
    exit 1
  }
  printf '%s\n' "$GENERATION" > "$temporary"
  chown root:legal-mcp-publisher "$temporary"
  chmod 440 "$temporary"
  sync -f "$temporary"
  mv -fT "$temporary" "$UPLOAD_AUTHORIZATION"
  sync -f "$RUNTIME_CONTROL"
}

path_is_absent() {
  [[ ! -e "$1" && ! -L "$1" ]]
}

reconcile_journal_preparation() {
  path_is_absent "$JOURNAL_PREPARING" && return 0
  [[ -d "$LIFECYCLE" && ! -L "$LIFECYCLE" \
    && "$(stat -c '%U:%G:%a' "$LIFECYCLE")" = root:legal-mcp:750 ]] || {
    echo 'cannot safely reconcile the deployment journal preparation' >&2
    exit 1
  }
  [[ -f "$JOURNAL_PREPARING" || -L "$JOURNAL_PREPARING" ]] || {
    echo 'deployment journal preparation has an unsafe file type' >&2
    exit 1
  }
  rm -f -- "$JOURNAL_PREPARING"
  path_is_absent "$JOURNAL_PREPARING" || {
    echo 'deployment journal preparation cleanup did not complete' >&2
    exit 1
  }
  sync -f "$LIFECYCLE"
}

reject_unknown_image_transaction_states() {
  local path
  while IFS= read -r -d '' path; do
    case "$path" in
      /etc/legal-mcp/.image-transaction|\
      /etc/legal-mcp/.image-transaction.preparing|\
      /etc/legal-mcp/.image-transaction.preparing-retired|\
      /etc/legal-mcp/.image-transaction.retiring|\
      /etc/legal-mcp/.image-transaction.retired|\
      /etc/legal-mcp/.image-transaction.deletion) ;;
      *)
        echo "unknown image transaction state must be reviewed before corpus deployment: $path" >&2
        exit 1
        ;;
    esac
  done < <(find /etc/legal-mcp -mindepth 1 -maxdepth 1 \
    -name '.image-transaction*' -print0)
}

reject_foreign_host_transactions() {
  local transaction
  [[ -d /etc/legal-mcp && ! -L /etc/legal-mcp \
    && "$(stat -c '%U:%G:%a' /etc/legal-mcp)" = root:root:755 ]] || {
    echo 'host transaction directory is not safely visible' >&2
    exit 1
  }
  require_acl /etc/legal-mcp $'user::rwx\ngroup::r-x\nother::r-x'
  reject_unknown_image_transaction_states
  for transaction in \
    /etc/legal-mcp/.auth-transaction.preparing \
    /etc/legal-mcp/.auth-transaction.preparing-retired \
    /etc/legal-mcp/.auth-transaction \
    /etc/legal-mcp/.auth-transaction.retiring \
    /etc/legal-mcp/.auth-transaction.retired \
    /etc/legal-mcp/.auth-transaction.legacy-v0192-preparing-retiring \
    /etc/legal-mcp/.auth-transaction.legacy-v0192-preparing-retired \
    /etc/legal-mcp/.image-transaction.preparing \
    /etc/legal-mcp/.image-transaction.preparing-retired \
    /etc/legal-mcp/.image-transaction \
    /etc/legal-mcp/.image-transaction.retiring \
    /etc/legal-mcp/.image-transaction.retired \
    /etc/legal-mcp/.image-transaction.deletion \
    /etc/legal-mcp/.host-tools-transaction.building \
    /etc/legal-mcp/.host-tools-transaction.building-retired \
    /etc/legal-mcp/.host-tools-transaction.preparing \
    /etc/legal-mcp/.host-tools-transaction.preparing-retired \
    /etc/legal-mcp/.host-tools-transaction \
    /etc/legal-mcp/.host-tools-transaction.retiring \
    /etc/legal-mcp/.host-tools-transaction.retired \
    /etc/legal-mcp/.host-tools-transaction.rollback-retiring \
    /etc/legal-mcp/.host-tools-transaction.rollback-retired \
    /etc/legal-mcp/.host-tools-transaction.publisher-restore \
    /etc/legal-mcp/.host-tools-transaction.publisher-restore-retired; do
    if [[ "$PAIR_ACTION" = true && "$transaction" = "$PAIR_TRANSACTION" ]]; then
      continue
    fi
    path_is_absent "$transaction" || {
      echo 'a foreign host transaction must be recovered before corpus deployment' >&2
      exit 1
    }
  done
  transaction="$(find /etc/legal-mcp -mindepth 1 -maxdepth 1 \
    -name '.auth-transaction.preparing.*' -print -quit)" || {
    echo 'could not inspect authentication transaction preparations' >&2
    exit 1
  }
  [[ -z "$transaction" ]] || {
    echo 'a foreign host transaction must be recovered before corpus deployment' >&2
    exit 1
  }
}

require_pair_dark_surface() {
  local listeners report admin_source
  path_is_absent "$AUTH_READY" || {
    echo 'pair lifecycle action requires authentication-ready to be absent' >&2
    exit 1
  }
  [[ "$(read_systemctl_enablement "$SERVICE")" = generated \
    && "$(read_systemctl_activity "$SERVICE")" = inactive \
    && "$(read_systemctl_enablement caddy.service)" = disabled \
    && "$(read_systemctl_activity caddy.service)" = inactive ]] || {
      echo 'pair lifecycle action requires the exact configured-dark service matrix' >&2
      exit 1
    }
  [[ -f /etc/legal-mcp/admin-source-ip && ! -L /etc/legal-mcp/admin-source-ip \
    && "$(stat -c '%U:%G:%a:%h' /etc/legal-mcp/admin-source-ip)" = root:root:600:1 ]] \
    || exit 1
  admin_source="$(</etc/legal-mcp/admin-source-ip)"
  [[ "$admin_source" =~ ^[0-9A-Fa-f:.]{2,45}$ ]] || exit 1
  report="$(ufw status verbose)" || exit 1
  printf '%s\n' "$report" | python3 /dev/fd/3 "$admin_source" 3<<'PY'
import re, sys
admin = sys.argv[1]
report = sys.stdin.read().splitlines()
if "Status: active" not in report:
    raise SystemExit(1)
if not any(re.fullmatch(r"Default: deny \(incoming\), allow \(outgoing\), (?:disabled|deny) \(routed\)", line) for line in report):
    raise SystemExit(1)
rules = []
for line in report:
    for action in ("ALLOW IN", "DENY IN", "REJECT IN", "LIMIT IN"):
        if action in line:
            left, right = line.split(action, 1)
            rules.append((left.strip(), action, right.split("#", 1)[0].strip()))
            break
if rules != [("22/tcp", "ALLOW IN", admin)]:
    raise SystemExit(1)
PY
  listeners="$(ss --listening --tcp --numeric --no-header)" || exit 1
  ! awk '$4 ~ /:(80|443|51235)$/ { found=1 } END { exit found ? 0 : 1 }' \
    <<< "$listeners" || {
      echo 'pair lifecycle action found a listener on 80, 443, or 51235' >&2
      exit 1
    }
}

read_pair_contract() {
  local name
  [[ "$PAIR_ACTION" = true \
    && "${LEGAL_MCP_PAIR_COORDINATOR:-}" = 1 \
    && "$INHERITED_LOCK_FD" =~ ^[0-9]+$ \
    && -e "/proc/$$/fd/$INHERITED_LOCK_FD" \
    && "$(stat -Lc '%d:%i' "/proc/$$/fd/$INHERITED_LOCK_FD" 2>/dev/null || true)" \
      = "$(stat -Lc '%d:%i' "$LOCK_FILE")" \
    && -d "$PAIR_TRANSACTION" && ! -L "$PAIR_TRANSACTION" \
    && "$(stat -c '%U:%G:%a' "$PAIR_TRANSACTION")" = root:root:700 ]] || {
      echo 'pair lifecycle action requires the live privileged coordinator transaction' >&2
      exit 1
    }
  for name in kind operation prior-generation target-generation retirement-outcome \
    saved-image target-image; do
    [[ -f "$PAIR_TRANSACTION/$name" && ! -L "$PAIR_TRANSACTION/$name" \
      && "$(stat -c '%U:%G:%a:%h' "$PAIR_TRANSACTION/$name")" = root:root:600:1 ]] || {
        echo "pair coordinator file is unsafe: $name" >&2
        exit 1
      }
  done
  [[ "$(<"$PAIR_TRANSACTION/kind")" = LEGAL_MCP_IMAGE_GENERATION_PAIR_TRANSACTION_V1 ]] || {
    echo 'pair coordinator transaction kind is not supported' >&2
    exit 1
  }
  PAIR_OPERATION="$(<"$PAIR_TRANSACTION/operation")"
  PAIR_PRIOR_GENERATION="$(<"$PAIR_TRANSACTION/prior-generation")"
  PAIR_TARGET_GENERATION="$(<"$PAIR_TRANSACTION/target-generation")"
  PAIR_OUTCOME="$(<"$PAIR_TRANSACTION/retirement-outcome")"
  [[ ( "$PAIR_OPERATION" = prepared || "$PAIR_OPERATION" = installed ) \
    && "$PAIR_PRIOR_GENERATION" =~ ^[0-9a-f]{64}$ \
    && "$PAIR_TARGET_GENERATION" =~ ^[0-9a-f]{64}$ \
    && "$PAIR_PRIOR_GENERATION" != "$PAIR_TARGET_GENERATION" \
    && "$PAIR_TARGET_GENERATION" = "$GENERATION" \
    && "$PAIR_OUTCOME" =~ ^(pending|saved|target)$ ]] || {
      echo 'pair coordinator transaction identity is malformed or mismatched' >&2
      exit 1
    }
  require_pair_dark_surface
}

require_abort_upload() {
  local upload="$1" mount_targets mount_target
  [[ -d "$upload" && ! -L "$upload" ]] || {
    echo 'abort upload path is not a real directory' >&2
    exit 1
  }
  require_owner_mode "$upload" "$PUBLISHER" "$PUBLISHER" 700
  require_acl "$upload" $'user::rwx\ngroup::---\nother::---'
  [[ "$(stat -c '%d' "$upload")" = "$(stat -c '%d' "$UPLOADS")" ]] || {
    echo 'abort upload is not on the corpus volume' >&2
    exit 1
  }
  mount_targets="$(
    findmnt --submounts --noheadings --raw --output TARGET --target "$upload"
  )" || {
    echo 'could not inspect abort upload mounts' >&2
    exit 1
  }
  [[ -n "$mount_targets" ]] || {
    echo 'could not locate the abort upload filesystem' >&2
    exit 1
  }
  while IFS= read -r mount_target; do
    [[ "$mount_target" != "$upload" && "$mount_target" != "$upload/"* ]] || {
      echo 'abort upload contains a mount point' >&2
      exit 1
    }
  done <<< "$mount_targets"
}

abort_generation() {
  local upload="$UPLOADS/$GENERATION"
  local temporary="$UPLOADS/.$GENERATION.preparing"
  local installed="$GENERATIONS/$GENERATION"
  local current

  if path_is_absent "$JOURNAL"; then
    current="$(active_generation)"
    if [[ "$current" = "$GENERATION" ]] \
      || ! path_is_absent "$upload" \
      || ! path_is_absent "$temporary" \
      || ! path_is_absent "$installed"; then
      echo 'generation has unexplained state and is not already aborted' >&2
      exit 1
    fi
    sync -f "$UPLOADS"
    sync -f "$LIFECYCLE"
    echo already-aborted
    exit 0
  fi

  read_journal
  [[ "$TX_GENERATION" = "$GENERATION" ]] || {
    echo 'generation does not match pending transaction' >&2
    exit 1
  }
  [[ "$TX_PHASE" = prepared || "$TX_PHASE" = aborting ]] || {
    echo 'only a prepared or aborting deployment transaction can be aborted' >&2
    exit 1
  }
  current="$(active_generation)"
  [[ "$current" = "$TX_PREVIOUS" && "$current" != "$GENERATION" ]] || {
    echo 'abort transaction does not match the active pointer' >&2
    exit 1
  }
  path_is_absent "$installed" || {
    echo 'abort target is already installed' >&2
    exit 1
  }
  path_is_absent "$temporary" || {
    echo 'abort transaction has an unexpected preparation directory' >&2
    exit 1
  }
  if path_is_absent "$upload"; then
    [[ "$TX_PHASE" = aborting ]] || {
      echo 'prepared abort upload is missing' >&2
      exit 1
    }
  else
    require_abort_upload "$upload"
  fi

  if [[ "$TX_PHASE" = prepared ]]; then
    write_journal aborting "$TX_PREVIOUS"
  fi
  if ! path_is_absent "$upload"; then
    rm -rf --one-file-system -- "$upload"
    path_is_absent "$upload" || {
      echo 'abort upload removal did not complete' >&2
      exit 1
    }
  fi
  sync -f "$UPLOADS"
  rm -f -- "$JOURNAL"
  path_is_absent "$JOURNAL" || {
    echo 'deployment journal removal did not complete' >&2
    exit 1
  }
  sync -f "$LIFECYCLE"
  echo aborted
  exit 0
}

probe_exact_generation() {
  local expected="$1"
  curl --fail --silent --max-time 5 http://127.0.0.1:51235/readyz 2>/dev/null |
    python3 -c 'import json,sys; value=json.load(sys.stdin); expected=sys.argv[1]; raise SystemExit(0 if value == {"status":"ok","generation":expected} else 1)' "$expected" 2>/dev/null
}

wait_for_exact_generation() {
  local expected="$1" deadline=$((SECONDS + 600)) activity
  while (( SECONDS < deadline )); do
    probe_exact_generation "$expected" && return 0
    activity="$(read_systemctl_activity "$SERVICE")" || return 1
    [[ "$activity" = active ]] || return 1
    sleep 1
  done
  return 1
}

running_image_is_pinned() {
  local expected_image_id running_image_id
  expected_image_id="$(podman image inspect "$IMAGE" --format '{{.Id}}')" || return 1
  running_image_id="$(podman inspect australian-legal-mcp --format '{{.Image}}')" || return 1
  [[ "$running_image_id" = "$expected_image_id" ]]
}

rollback_pointer() {
  local previous="$1"
  if [[ "$previous" = - ]]; then
    run_legal deactivate --expected-generation "$GENERATION" >/dev/null
  else
    run_legal rollback --generation "$previous" >/dev/null
  fi
}

require_pair_image() {
  local choice="$1" expected
  case "$choice" in
    saved) expected="$PAIR_TRANSACTION/saved-image" ;;
    target) expected="$PAIR_TRANSACTION/target-image" ;;
    *) exit 1 ;;
  esac
  cmp --silent "$IMAGE_FILE" "$expected" || {
    echo "pair lifecycle action does not use the recorded $choice image" >&2
    exit 1
  }
}

require_sealed_pair_upload() {
  local upload="$UPLOADS/$GENERATION"
  [[ -d "$upload" && ! -L "$upload" \
    && "$(stat -c '%U:%G:%a' "$upload")" = root:legal-mcp:550 ]] || {
      echo 'pair candidate is not an exact sealed upload' >&2
      exit 1
    }
  [[ -f "$upload/generation.json" && ! -L "$upload/generation.json" \
    && "$(stat -c '%U:%G:%a:%h' "$upload/generation.json")" \
      = root:legal-mcp:440:1 ]] || {
      echo 'sealed pair candidate manifest is unsafe' >&2
      exit 1
    }
}

pair_seal_generation() {
  local current
  read_pair_contract
  require_pair_image saved
  current="$(active_generation)"
  [[ "$current" = "$PAIR_PRIOR_GENERATION" ]] || {
    echo 'pair preparation does not match the prior active generation' >&2
    exit 1
  }
  case "$PAIR_OPERATION" in
    prepared)
      read_journal
      [[ "$TX_GENERATION" = "$GENERATION" \
        && "$TX_PREVIOUS" = "$PAIR_PRIOR_GENERATION" \
        && "$TX_PHASE" = prepared \
        && -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" \
        && ! -e "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]] || {
          echo 'pair preparation requires the exact ordinary prepared upload' >&2
          exit 1
        }
      seal_upload_for_pair
      require_sealed_pair_upload
      ;;
    installed)
      path_is_absent "$JOURNAL" || {
        echo 'installed pair rollback refuses a corpus deployment transaction' >&2
        exit 1
      }
      [[ -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" \
        && ! -e "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]] || {
          echo 'installed pair rollback target is not one unambiguous generation' >&2
          exit 1
        }
      ;;
  esac
  echo pair-prepared
}

pair_activate_generation() {
  local activation_ok=false current
  read_pair_contract
  require_pair_image target
  current="$(active_generation)"
  case "$PAIR_OPERATION" in
    prepared)
      read_journal
      [[ "$TX_GENERATION" = "$GENERATION" \
        && "$TX_PREVIOUS" = "$PAIR_PRIOR_GENERATION" ]] || {
          echo 'pair activation does not match its prepared corpus transaction' >&2
          exit 1
        }
      case "$TX_PHASE" in
        prepared)
          [[ "$current" = "$PAIR_PRIOR_GENERATION" ]] || exit 1
          require_sealed_pair_upload
          write_journal activating "$PAIR_PRIOR_GENERATION"
          if activate_prepared_upload >/dev/null; then activation_ok=true; fi
          ;;
        activating)
          if [[ "$current" = "$GENERATION" ]]; then
            activation_ok=true
          elif [[ "$current" = "$PAIR_PRIOR_GENERATION" \
            && -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" \
            && ! -e "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]]; then
            require_sealed_pair_upload
            if activate_prepared_upload >/dev/null; then activation_ok=true; fi
          elif [[ "$current" = "$PAIR_PRIOR_GENERATION" \
            && -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" \
            && ! -e "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]]; then
            if run_legal rollback --generation "$GENERATION" >/dev/null; then activation_ok=true; fi
          else
            echo 'pair activation cannot locate one unambiguous candidate' >&2
            exit 1
          fi
          ;;
        activated)
          [[ "$current" = "$GENERATION" ]] && activation_ok=true
          ;;
        *)
          echo 'pair corpus transaction is not activatable' >&2
          exit 1
          ;;
      esac
      [[ "$activation_ok" = true && "$(active_generation)" = "$GENERATION" ]] || {
        echo 'pair target generation validation or activation failed' >&2
        exit 1
      }
      write_journal activated "$PAIR_PRIOR_GENERATION"
      ;;
    installed)
      path_is_absent "$JOURNAL" || exit 1
      if [[ "$current" = "$PAIR_PRIOR_GENERATION" ]]; then
        run_legal rollback --generation "$GENERATION" >/dev/null
      elif [[ "$current" != "$GENERATION" ]]; then
        echo 'installed pair activation found a pointer outside the recorded pair' >&2
        exit 1
      fi
      ;;
  esac
  [[ "$(active_generation)" = "$GENERATION" ]]
  run_legal verify --quiet >/dev/null
  echo pair-activated-dark
}

pair_restore_generation() {
  local current installed="$GENERATIONS/$GENERATION" upload="$UPLOADS/$GENERATION"
  read_pair_contract
  require_pair_image saved
  current="$(active_generation)"
  if [[ "$current" = "$GENERATION" ]]; then
    if [[ "$PAIR_OPERATION" = prepared ]]; then
      write_journal rolling-back "$PAIR_PRIOR_GENERATION"
    fi
    run_legal rollback --generation "$PAIR_PRIOR_GENERATION" >/dev/null
    current="$(active_generation)"
  fi
  [[ "$current" = "$PAIR_PRIOR_GENERATION" ]] || {
    echo 'pair restore found a pointer outside the recorded pair' >&2
    exit 1
  }
  case "$PAIR_OPERATION" in
    prepared)
      [[ -f "$JOURNAL" && ! -L "$JOURNAL" ]] || exit 1
      if [[ -d "$installed" && ! -L "$installed" ]]; then
        path_is_absent "$upload" || {
          echo 'pair restore found the candidate in both installed and upload locations' >&2
          exit 1
        }
        mv -T "$installed" "$upload"
        sync -f "$GENERATIONS"
        sync -f "$UPLOADS"
      fi
      [[ -d "$upload" && ! -L "$upload" \
        && ! -e "$installed" && ! -L "$installed" ]] || {
          echo 'pair restore cannot locate its preserved prepared candidate' >&2
          exit 1
        }
      restore_upload_to_publisher
      write_journal prepared "$PAIR_PRIOR_GENERATION"
      ;;
    installed)
      path_is_absent "$JOURNAL" || exit 1
      [[ -d "$installed" && ! -L "$installed" \
        && -d "$GENERATIONS/$PAIR_PRIOR_GENERATION" \
        && ! -L "$GENERATIONS/$PAIR_PRIOR_GENERATION" \
        && ! -e "$upload" && ! -L "$upload" ]] || {
          echo 'installed pair restore lost one member of the retained pair' >&2
          exit 1
        }
      ;;
  esac
  run_legal verify --quiet >/dev/null
  echo pair-restored-dark
}

pair_commit_generation() {
  local current
  read_pair_contract
  [[ "$PAIR_OUTCOME" = saved || "$PAIR_OUTCOME" = target ]] || {
    echo 'pair commit decision is not durable' >&2
    exit 1
  }
  require_pair_image "$PAIR_OUTCOME"
  current="$(active_generation)"
  case "$PAIR_OPERATION:$PAIR_OUTCOME" in
    prepared:target)
      read_journal
      [[ "$TX_GENERATION" = "$GENERATION" \
        && "$TX_PREVIOUS" = "$PAIR_PRIOR_GENERATION" \
        && "$TX_PHASE" = activated && "$current" = "$GENERATION" \
        && -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" \
        && ! -e "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]] || exit 1
      rm -f -- "$JOURNAL"
      path_is_absent "$JOURNAL" || exit 1
      sync -f "$LIFECYCLE"
      ;;
    prepared:saved)
      read_journal
      [[ "$TX_GENERATION" = "$GENERATION" \
        && "$TX_PREVIOUS" = "$PAIR_PRIOR_GENERATION" \
        && "$TX_PHASE" = prepared && "$current" = "$PAIR_PRIOR_GENERATION" \
        && -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" \
        && "$(stat -c '%U:%G:%a' "$UPLOADS/$GENERATION")" \
          = legal-mcp-publisher:legal-mcp-publisher:700 \
        && ! -e "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]] || exit 1
      ;;
    installed:target)
      [[ "$current" = "$GENERATION" && -d "$GENERATIONS/$PAIR_PRIOR_GENERATION" \
        && ! -L "$GENERATIONS/$PAIR_PRIOR_GENERATION" ]] || exit 1
      path_is_absent "$JOURNAL" || exit 1
      ;;
    installed:saved)
      [[ "$current" = "$PAIR_PRIOR_GENERATION" && -d "$GENERATIONS/$GENERATION" \
        && ! -L "$GENERATIONS/$GENERATION" ]] || exit 1
      path_is_absent "$JOURNAL" || exit 1
      ;;
    *) exit 1 ;;
  esac
  run_legal verify --quiet >/dev/null
  echo pair-committed-dark
}

# The fixed journal preparation is non-authoritative until its atomic rename.
# Reconcile it under the shared lock before classifying foreign transactions so
# a killed write_journal cannot deadlock its own coordinator recovery.
reconcile_journal_preparation
reject_foreign_host_transactions

if [[ "$PAIR_ACTION" = true ]]; then
  require_commands awk blkid chmod chown find findmnt getfacl grep id mv podman \
    python3 setfacl ss systemctl ufw xfs_info
  validate_host_state
  require_fixed_host_identities
  read_image
  clear_upload_authorization
  case "$ACTION" in
    pair-seal) pair_seal_generation ;;
    pair-activate) pair_activate_generation ;;
    pair-restore) pair_restore_generation ;;
    pair-commit) pair_commit_generation ;;
  esac
  exit 0
fi

if [[ "$ACTION" = abort ]]; then
  # Revocation is the first mutation after the foreign-transaction guard. It is
  # durable before any potentially slow volume or journal checks.
  clear_upload_authorization
  require_commands blkid chmod chown findmnt getfacl grep id mv xfs_info
  validate_host_state
  require_fixed_host_identities
  abort_generation
fi

require_commands blkid cp curl df find findmnt getfacl getent grep id mv podman python3 \
  setfacl systemctl xfs_info
validate_host_state
require_fixed_host_identities
read_image

if [[ "$ACTION" = prepare ]]; then
  service_activity=''
  clear_upload_authorization
  previous="$(active_generation)"
  if [[ ! -e "$JOURNAL" && "$previous" = "$GENERATION" ]]; then
    service_activity="$(read_systemctl_activity "$SERVICE")" || exit 1
    if [[ "$service_activity" = active ]] \
      && wait_for_exact_generation "$GENERATION" \
      && running_image_is_pinned; then
      echo already-active
      exit 0
    fi
    echo 'generation is active but the service is not exactly ready; repair authentication or service state' >&2
    exit 1
  fi
  if [[ -e "$JOURNAL" ]]; then
    read_journal
    [[ "$TX_GENERATION" = "$GENERATION" ]] || {
      echo "another generation transaction is pending: $TX_GENERATION" >&2
      exit 1
    }
    case "$TX_PHASE" in
      prepared)
        [[ -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]] || {
          echo 'prepared transaction has no upload directory' >&2
          exit 1
        }
        authorize_upload
        echo prepared
        exit 0
        ;;
      activated|rolling-back|rolled-back)
        echo staged
        exit 0
        ;;
      activating)
        current="$(active_generation)"
        if [[ "$current" = "$GENERATION" ]]; then
          write_journal activated "$TX_PREVIOUS"
          echo staged
          exit 0
        fi
        [[ "$current" = "$TX_PREVIOUS" ]] || {
          echo 'activating transaction has an unexpected active pointer' >&2
          exit 1
        }
        if [[ -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]]; then
          restore_upload_to_publisher
          write_journal prepared "$TX_PREVIOUS"
          authorize_upload
          echo prepared
          exit 0
        fi
        if [[ -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]]; then
          write_journal rolled-back "$TX_PREVIOUS"
          echo staged
          exit 0
        fi
        echo 'activating transaction has neither upload nor installed generation' >&2
        exit 1
        ;;
      preparing)
        rm -rf --one-file-system "$UPLOADS/.$GENERATION.preparing"
        ;;
      aborting)
        echo 'deployment transaction is aborting; finish the explicit abort first' >&2
        exit 1
        ;;
    esac
    previous="$TX_PREVIOUS"
  else
    if [[ -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]]; then
      write_journal rolled-back "$previous"
      echo staged
      exit 0
    fi
    write_journal preparing "$previous"
  fi

  upload="$UPLOADS/$GENERATION"
  temporary="$UPLOADS/.$GENERATION.preparing"
  if [[ ! -e "$upload" ]]; then
    available_bytes="$(df --block-size=1 --output=avail "$DATA_ROOT" | tail -n 1 | tr -d ' ')"
    [[ "$available_bytes" =~ ^[0-9]+$ && "$available_bytes" -ge 5368709120 ]] || {
      echo 'corpus volume has less than the required 5-GiB free margin' >&2
      exit 1
    }
    rm -rf --one-file-system "$temporary"
    mkdir -m 700 "$temporary"
    if [[ "$previous" != - ]]; then
      cp --archive --one-file-system --reflink=always "$GENERATIONS/$previous/." "$temporary/"
    fi
    chown -R "$publisher_uid:$publisher_gid" "$temporary"
    find "$temporary" -xdev -type d -exec chmod 700 {} +
    find "$temporary" -xdev -type f -exec chmod 600 {} +
    mv -T "$temporary" "$upload"
    sync -f "$UPLOADS"
  else
    [[ -d "$upload" && ! -L "$upload" ]] || { echo 'upload path is unsafe' >&2; exit 1; }
  fi
  write_journal prepared "$previous"
  authorize_upload
  echo prepared
  exit 0
fi

clear_upload_authorization
[[ -e "$JOURNAL" ]] || { echo 'no prepared deployment transaction exists' >&2; exit 1; }
read_journal
[[ "$TX_GENERATION" = "$GENERATION" ]] || { echo 'generation does not match pending transaction' >&2; exit 1; }
[[ "$TX_PHASE" != preparing && "$TX_PHASE" != aborting ]] || {
  echo 'deployment upload has not completed preparation' >&2
  exit 1
}

was_active=false
service_activity="$(read_systemctl_activity "$SERVICE")" || exit 1
if [[ "$service_activity" = active ]]; then
  was_active=true
  systemctl stop "$SERVICE"
  service_activity="$(read_systemctl_activity "$SERVICE")" || exit 1
  [[ "$service_activity" = inactive ]] || {
    echo 'legal-mcp service did not become inactive' >&2
    exit 1
  }
fi

case "$TX_PHASE" in
  prepared)
    write_journal activating "$TX_PREVIOUS"
    normalize_upload_for_activation
    activation_ok=false
    if activate_prepared_upload >/dev/null; then
      activation_ok=true
    fi
    ;;
  activating)
    current="$(active_generation)"
    if [[ "$current" = "$GENERATION" ]]; then
      activation_ok=true
    elif [[ "$current" = "$TX_PREVIOUS" \
      && -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]]; then
      normalize_upload_for_activation
      activation_ok=false
      if activate_prepared_upload >/dev/null; then
        activation_ok=true
      fi
    elif [[ "$current" = "$TX_PREVIOUS" \
      && -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]]; then
      activation_ok=false
      if run_legal rollback --generation "$GENERATION" >/dev/null; then
        activation_ok=true
      fi
    else
      echo 'activating transaction cannot locate one unambiguous candidate' >&2
      exit 1
    fi
    ;;
  rolled-back)
    [[ "$(active_generation)" = "$TX_PREVIOUS" ]] || {
      echo 'rolled-back transaction does not match the previous pointer' >&2
      exit 1
    }
    run_legal rollback --generation "$GENERATION" >/dev/null
    write_journal activated "$TX_PREVIOUS"
    ;;
  rolling-back)
    current="$(active_generation)"
    if [[ "$current" = "$GENERATION" ]]; then
      rollback_pointer "$TX_PREVIOUS"
    elif [[ "$current" != "$TX_PREVIOUS" ]]; then
      echo 'rolling-back transaction has an unexpected active pointer' >&2
      exit 1
    fi
    write_journal rolled-back "$TX_PREVIOUS"
    run_legal rollback --generation "$GENERATION" >/dev/null
    write_journal activated "$TX_PREVIOUS"
    ;;
  activated)
    [[ "$(active_generation)" = "$GENERATION" ]] || {
      echo 'activated transaction does not match the active pointer' >&2
      exit 1
    }
    ;;
esac

if [[ "$TX_PHASE" = prepared || "$TX_PHASE" = activating ]]; then
  if [[ "$activation_ok" = true ]]; then
    write_journal activated "$TX_PREVIOUS"
  else
      current="$(active_generation)"
      if [[ "$current" = "$GENERATION" ]]; then
        write_journal rolling-back "$TX_PREVIOUS"
        rollback_pointer "$TX_PREVIOUS"
        write_journal rolled-back "$TX_PREVIOUS"
      else
        [[ "$current" = "$TX_PREVIOUS" ]] || {
          echo 'activation failed with an unexpected active pointer' >&2
          exit 1
        }
        if [[ -d "$UPLOADS/$GENERATION" && ! -L "$UPLOADS/$GENERATION" ]]; then
          restore_upload_to_publisher
          write_journal prepared "$TX_PREVIOUS"
        elif [[ -d "$GENERATIONS/$GENERATION" && ! -L "$GENERATIONS/$GENERATION" ]]; then
          write_journal rolled-back "$TX_PREVIOUS"
        else
          echo 'failed activation lost both candidate locations' >&2
          exit 1
        fi
      fi
      if [[ "$was_active" = true ]]; then
        [[ "$TX_PREVIOUS" != - ]] || { echo 'no previous service should be active' >&2; exit 1; }
        systemctl start "$SERVICE"
        if ! wait_for_exact_generation "$TX_PREVIOUS" || ! running_image_is_pinned; then
          echo 'activation failed and the previous service did not recover' >&2
          exit 1
        fi
      fi
      echo 'remote generation validation or activation failed' >&2
      exit 1
  fi
fi

# Bootstrap activation intentionally stops before starting a public-capable
# service. Authentication is configured and probed in a separate transaction.
if [[ "$TX_PREVIOUS" = - && "$was_active" = false ]]; then
  rm -f "$JOURNAL"
  sync -f "$LIFECYCLE"
  echo activated-pending-auth
  exit 0
fi

if systemctl start "$SERVICE" \
  && wait_for_exact_generation "$GENERATION" \
  && running_image_is_pinned; then
  run_legal verify --quiet >/dev/null
  # Hosted generations are retained for explicit pair rollback. Pruning is a
  # separate, reviewed maintenance action and must never follow activation.
  rm -f "$JOURNAL"
  sync -f "$LIFECYCLE"
  echo activated
  exit 0
fi

systemctl stop "$SERVICE"
service_activity="$(read_systemctl_activity "$SERVICE")" || exit 1
[[ "$service_activity" = inactive ]] || {
  echo 'failed legal-mcp service did not become inactive' >&2
  exit 1
}
write_journal rolling-back "$TX_PREVIOUS"
if [[ "$TX_PREVIOUS" = - ]]; then
  rollback_pointer "$TX_PREVIOUS"
else
  rollback_pointer "$TX_PREVIOUS"
  write_journal rolled-back "$TX_PREVIOUS"
  if [[ "$was_active" = true ]]; then
    systemctl start "$SERVICE"
    if ! wait_for_exact_generation "$TX_PREVIOUS" || ! running_image_is_pinned; then
      echo 'new generation failed and the previous service did not recover' >&2
      exit 1
    fi
  fi
fi
if [[ "$TX_PREVIOUS" = - ]]; then write_journal rolled-back "$TX_PREVIOUS"; fi
echo 'new generation failed readiness and the previous state was restored' >&2
exit 1
